<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/jelly_button_pressed" />
            <corners android:radius="20dp" />
            <stroke android:width="1.5dp" android:color="@color/jelly_pink_deep" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/jelly_button_selected" />
            <corners android:radius="20dp" />
            <stroke android:width="1.5dp" android:color="@color/jelly_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E6FFD4E8"
                android:endColor="#E6D4E0F5"
                android:angle="45"
                android:type="linear" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#60FFB6D9" />
        </shape>
    </item>
</selector>
