<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:gravity="center_horizontal">

        <!-- 读取游戏进程 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_read_game_process"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="读取游戏进程"
                android:textSize="12sp"
                android:background="@drawable/jelly_button_bg"
                android:textColor="@color/jelly_text_primary" />

            <TextView
                android:id="@+id/tv_process_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未读取"
                android:textSize="11sp"
                android:textColor="@android:color/holo_red_dark"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 建模绘制总开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="建模绘制"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/jelly_text_primary" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_model_draw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false" />

            <Button
                android:id="@+id/btn_enable_all_draw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="一键开启全部"
                android:textSize="11sp"
                android:layout_marginStart="8dp"
                android:enabled="false"
                android:background="@drawable/jelly_button_bg"
                android:textColor="@color/jelly_text_primary" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22000000" android:layout_marginBottom="8dp"/>

        <!-- 人物建模 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="人物建模绘制" android:textSize="13sp" android:textColor="@color/jelly_text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_player_model" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
        </LinearLayout>

        <!-- 血量 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="血量绘制" android:textSize="13sp" android:textColor="@color/jelly_text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_health_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
        </LinearLayout>

        <!-- 方框 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="方框绘制" android:textSize="13sp" android:textColor="@color/jelly_text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_box_esp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
        </LinearLayout>

        <!-- 距离 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="距离绘制" android:textSize="13sp" android:textColor="@color/jelly_text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_distance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
        </LinearLayout>

        <!-- 体力 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="体力绘制" android:textSize="13sp" android:textColor="@color/jelly_text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_stamina" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
        </LinearLayout>

        <!-- 负重 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="负重绘制" android:textSize="13sp" android:textColor="@color/jelly_text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_weight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
        </LinearLayout>

        <!-- 物资绘制 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="物资绘制" android:textSize="13sp" android:textColor="@color/jelly_text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_loot" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="8dp" android:paddingStart="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="价格区间：" android:textSize="11sp" android:textColor="@color/jelly_text_secondary"/>
            <EditText android:id="@+id/et_price_min" android:layout_width="60dp" android:layout_height="wrap_content" android:inputType="number" android:text="0" android:textSize="11sp" android:enabled="false"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="～" android:textSize="11sp" android:textColor="@color/jelly_text_secondary"/>
            <EditText android:id="@+id/et_price_max" android:layout_width="60dp" android:layout_height="wrap_content" android:inputType="number" android:text="1000000" android:textSize="11sp" android:enabled="false"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn_price_1k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1K" android:textSize="10sp" android:minWidth="0dp" android:paddingHorizontal="8dp" android:enabled="false" android:background="@drawable/jelly_button_bg" android:textColor="@color/jelly_text_primary"/>
            <Button android:id="@+id/btn_price_10k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1万" android:textSize="10sp" android:minWidth="0dp" android:paddingHorizontal="8dp" android:layout_marginStart="4dp" android:enabled="false" android:background="@drawable/jelly_button_bg" android:textColor="@color/jelly_text_primary"/>
            <Button android:id="@+id/btn_price_100k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10万" android:textSize="10sp" android:minWidth="0dp" android:paddingHorizontal="8dp" android:layout_marginStart="4dp" android:enabled="false" android:background="@drawable/jelly_button_bg" android:textColor="@color/jelly_text_primary"/>
            <Button android:id="@+id/btn_price_1m" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100万" android:textSize="10sp" android:minWidth="0dp" android:paddingHorizontal="8dp" android:layout_marginStart="4dp" android:enabled="false" android:background="@drawable/jelly_button_bg" android:textColor="@color/jelly_text_primary"/>
        </LinearLayout>

        <!--绘制宝箱 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="📦 绘制宝箱" android:textSize="13sp" android:textColor="@color/jelly_text_primary"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_draw_chests" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/layout_chest_filter" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:layout_marginBottom="8dp" android:paddingStart="16dp" android:alpha="0.5">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="品质：" android:textSize="10sp" android:textColor="@color/jelly_text_secondary"/>
            <CheckBox android:id="@+id/cb_chest_common" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="普通" android:textSize="9sp" android:checked="true" android:enabled="false"/>
            <CheckBox android:id="@+id/cb_chest_rare" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="稀有" android:textSize="9sp" android:checked="true" android:enabled="false"/>
            <CheckBox android:id="@+id/cb_chest_epic" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="史诗" android:textSize="9sp" android:checked="true" android:enabled="false"/>
            <CheckBox android:id="@+id/cb_chest_legendary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="传说" android:textSize="9sp" android:checked="true" android:enabled="false"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/layout_chest_distance" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="8dp" android:paddingStart="16dp" android:alpha="0.5">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="距离：" android:textSize="10sp" android:textColor="@color/jelly_text_secondary"/>
            <SeekBar android:id="@+id/seekbar_chest_distance" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="2500" android:progress="1000" android:enabled="false"/>
            <TextView android:id="@+id/tv_chest_distance" android:layout_width="40dp" android:layout_height="wrap_content" android:text="1000m" android:textSize="10sp" android:textColor="@color/jelly_text_secondary" android:gravity="center"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="* 建模绘制总开关生效前提：已成功读取游戏进程" android:textSize="9sp" android:textColor="@color/jelly_text_secondary"/>
    </LinearLayout>
</ScrollView>
